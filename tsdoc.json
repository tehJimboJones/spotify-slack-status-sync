{
    "$schema": "https://developer.microsoft.com/json-schemas/tsdoc/v0/tsdoc.schema.json",
    "tagDefinitions": [
        {
            "tagName": "@author",
            "syntaxKind": "block",
            "allowMultiple": true
        },
        {
            "tagName": "@date",
            "syntaxKind": "block",
            "allowMultiple": false
        },
        {
            "tagName": "@copyright",
            "syntaxKind": "block",
            "allowMultiple": false
        }
    ],
    "supportFlags": {
        "supportedHtmlElements": [
            "b",
            "i",
            "p",
            "br"
        ]
    }
}